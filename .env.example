# Environment variables for Smart Nike Shoe Ad Studio.
#
# Copy this file to `.env` and fill in your Hugging Face settings.
# The app loads this file automatically via python-dotenv.
#
# Hugging Face token (needed for Inference API calls)
HF_TOKEN=your_huggingface_token_here

# Optional model overrides
PROFILE_EMBEDDING_MODEL_ID=sentence-transformers/all-MiniLM-L6-v2
PRODUCT_CLIP_MODEL_ID=openai/clip-vit-base-patch32
SLOGAN_GENERATION_MODEL_ID=Qwen/Qwen3.5-2B
SCRIPT_GENERATION_MODEL_ID=Qwen/Qwen3.5-2B
SCENE_IMAGE_MODEL_ID=F16/z-image-turbo-sda
VIDEO_MODEL_ID=Wan-AI/Wan2.2-TI2V-5B

# Runtime controls
USE_HF_INFERENCE_API_FOR_VIDEO=true
USE_LOCAL_DIFFUSERS_VIDEO=false
FORCE_MOCK_MODE=false