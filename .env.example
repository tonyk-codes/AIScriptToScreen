# Environment variables for the AI Script-to-Screen pipeline.
#
# Copy this file to `.env` and fill in your real API keys.
# The pipeline loads this file automatically via python-dotenv.
#
# Hugging Face (used by open-source model integrations)
HF_TOKEN=your_huggingface_token_here

# OpenAI (for GPT-4 script refinement, if integrated)
OPENAI_API_KEY=your_openai_api_key_here

# Runway (for video generation, if integrated)
RUNWAY_API_KEY=your_runway_api_key_here

# Seedance (for video generation, if integrated)
SEEDANCE_API_KEY=your_seedance_api_key_here

# Kimi (for script refinement, if integrated)
KIMI_API_KEY=your_kimi_api_key_here